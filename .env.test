# =========================================================
# 测试环境配置
# 用途：
# - HBuilderX 打测试包
# - 给测试同事 / 验收同事安装联调
#
# 这份文件应该指向测试环境地址，例如 test-api.dogdogdoll.com。
# 真正决定当前打包读取哪份 .env 的开关在 `common/build-profile.js`。
# =========================================================

# 环境标识，主要用于启动日志确认
VUE_APP_ENV_NAME=test
VITE_APP_ENV_NAME=test

# 默认 API 地址
VUE_APP_API_CN=https://test-api.dogdogdoll.com/
VUE_APP_API_US=https://us-api.dogdogdoll.com
VUE_APP_API_DEV=https://test-api.dogdogdoll.com/
VITE_APP_API_CN=https://test-api.dogdogdoll.com/
VITE_APP_API_US=https://us-api.dogdogdoll.com
VITE_APP_API_DEV=https://test-api.dogdogdoll.com/

# 其它区域 API 预留
VUE_APP_API_EU=
VUE_APP_API_JP=
VUE_APP_API_SG=
VITE_APP_API_EU=
VITE_APP_API_JP=
VITE_APP_API_SG=

# 站点地址
VUE_APP_WEB_WWW=https://www.dogdogdoll.com
VUE_APP_WEB_H5=https://m.dogdogdoll.com
VITE_APP_WEB_WWW=https://www.dogdogdoll.com
VITE_APP_WEB_H5=https://m.dogdogdoll.com

# 图片域名
VUE_APP_IMAGE1_URL=https://images1.fantuanpu.com
VITE_APP_IMAGE1_URL=https://images1.fantuanpu.com

# 是否允许设备本地 selectedServer 覆盖默认后端
# 测试环境按需开启；如果希望包内地址固定，就改成 false
VUE_APP_ALLOW_SELECTED_SERVER_OVERRIDE=true
VITE_APP_ALLOW_SELECTED_SERVER_OVERRIDE=true
